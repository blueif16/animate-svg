{
  "id": "w0-pedagogy",
  "phase": "pedagogy",
  "deps": ["setup-scaffold"],
  "prompt": { "file": "prompt.md" },
  "tools": { "allow": ["read", "write", "edit", "submit_result"], "deny": [] },
  "inject": [
    "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/brief.md"
  ],
  "contract": {
    "artifacts": [
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/pedagogy.md"
    ],
    "owns": [
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/pedagogy.md",
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/_logs/w0-pedagogy.md"
    ],
    "readScope": [
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}",
      "{{WORKSPACE}}/remotion-svg-primitives/src/capabilities/catalog-digest.md",
      "{{WORKSPACE}}/.agents"
    ],
    "returnMode": "optional"
  },
  "checks": {
    "post": [
      { "kind": "non-empty", "path": "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/pedagogy.md" }
    ]
  },
  "policy": { "fail": "block" },
  "return": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "node": { "type": "string" },
      "status": { "type": "string", "enum": ["ok", "gap", "blocked"] },
      "outputArtifacts": { "type": "array", "items": { "type": "string" } },
      "summary": { "type": "string" },
      "issues": { "type": "array", "items": { "type": "string" } },
      "pipelineFindings": { "type": "array", "items": { "type": "string" } }
    },
    "required": ["node", "status", "outputArtifacts", "summary", "pipelineFindings"]
  }
}
