{
  "id": "w2c-sound-design",
  "phase": "design",
  "deps": [
    "w2a-visual-design"
  ],
  "prompt": { "file": "prompt.md" },
  "tools": { "allow": ["read", "write", "edit", "submit_result"], "deny": [] },
  "inject": [
    "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/brief.md",
    "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/pedagogy.md",
    "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/visual-design.md"
  ],
  "contract": {
    "artifacts": [
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/audio-cues.json"
    ],
    "schema": "{{WORKSPACE}}/.piflow/lesson-build/template/nodes/w2c-sound-design/audio-cues.schema.json",
    "owns": [
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/audio-cues.json",
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/_logs/w2c-sound-design.md"
    ],
    "readScope": [
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}",
      "{{WORKSPACE}}/.agents",
      "{{WORKSPACE}}/../shared-sound/public/audio"
    ],
    "returnMode": "optional"
  },
  "checks": {
    "post": [
      { "kind": "non-empty", "path": "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/audio-cues.json" },
      { "kind": "json-parses", "path": "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/audio-cues.json" }
    ]
  },
  "policy": { "fail": "block" },
  "optimize": {
    "criteria": "nodes/w2c-sound-design/criteria.md",
    "measure": [
      {
        "id": "w2c-hard-checks",
        "run": {
          "cmd": "{{WORKSPACE}}/remotion-svg-primitives/node_modules/.bin/tsx",
          "args": [
            "{{WORKSPACE}}/.piflow/lesson-build/template/nodes/w2c-sound-design/scripts/measure.mjs",
            "--run",
            "{{RUN}}",
            "--workspace",
            "{{WORKSPACE}}",
            "--out",
            "{{RUN}}/optimize/substrate/w2c-sound-design.measure.json"
          ]
        },
        "writes": [
          "{{RUN}}/optimize/substrate/w2c-sound-design.measure.json"
        ],
        "note": "registry-membership (C5) + density ceilings (≤1 sfx/cue, ≤1 ta-da) + the ALREADY-EXISTING assertConcurrentAudioBudget()/MAX_CONCURRENT_AUDIO (invoked directly, never reimplemented; see scripts/measure.mjs header + [[sound-design-sfx]]) — the three deterministic invariants criteria.md's 'Wiring + readiness' documented but that no CHECK_KINDS predicate can express (cross-registry membership; per-cue grouping). lessonId is derived IN-SCRIPT from <run>/.pi/run.json's recorded artifact paths (robust across runs that predate {{arg.*}} persistence in optimize.measure's ResolveCtx), never from {{arg.lessonId}}."
      }
    ]
  },
  "return": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "node": { "type": "string" },
      "status": { "type": "string", "enum": ["ok", "gap", "blocked"] },
      "outputArtifacts": { "type": "array", "items": { "type": "string" } },
      "summary": { "type": "string" },
      "issues": { "type": "array", "items": { "type": "string" } },
      "pipelineFindings": { "type": "array", "items": { "type": "string" } }
    },
    "required": ["node", "status", "outputArtifacts", "summary", "pipelineFindings"]
  }
}
