{
  "id": "w6-verification",
  "phase": "verify",
  "deps": [
    "w5-render"
  ],
  "prompt": {
    "file": "prompt.md"
  },
  "tools": {
    "allow": [
      "read",
      "write",
      "edit",
      "bash",
      "submit_result"
    ],
    "deny": []
  },
  "inject": [
    "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/pedagogy.md"
  ],
  "contract": {
    "artifacts": [
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/verification.md"
    ],
    "owns": [
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/verification.md",
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/_logs/w6-verification.md"
    ],
    "readScope": [
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}",
      "{{WORKSPACE}}/.agents"
    ],
    "returnMode": "optional"
  },
  "checks": {
    "post": [
      {
        "kind": "non-empty",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/verification.md"
      }
    ]
  },
  "policy": {
    "fail": "block"
  },
  "return": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "node": { "type": "string" },
      "status": { "type": "string", "enum": ["ok", "gap", "blocked"] },
      "outputArtifacts": { "type": "array", "items": { "type": "string" } },
      "summary": { "type": "string" },
      "issues": { "type": "array", "items": { "type": "string" } },
      "pipelineFindings": { "type": "array", "items": { "type": "string" } }
    },
    "required": ["node", "status", "outputArtifacts", "summary", "pipelineFindings"]
  },
  "optimize": {
    "measure": [
      {
        "id": "bbox-overlay-produced",
        "run": {
          "cmd": "node",
          "args": [
            "{{WORKSPACE}}/.piflow/lesson-build/template/nodes/w6-verification/gen/check-bbox-overlay-produced.mjs",
            "--workspace", "{{WORKSPACE}}",
            "--run", "{{RUN}}",
            "--report-out", "{{RUN}}/optimize/substrate/bbox-overlay-produced.json"
          ],
          "note": "MEASURE (post-run, report-only): the prompt's REVIEW SURFACE law requires running `npm run lesson:bbox` before judging any collision/size question — this checks the side effect (out/<id>/bbox-overlay/*.png) actually exists, i.e. the command actually ran."
        },
        "writes": ["{{RUN}}/optimize/substrate/bbox-overlay-produced.json"]
      },
      {
        "id": "cue-coverage",
        "run": {
          "cmd": "node",
          "args": [
            "{{WORKSPACE}}/.piflow/lesson-build/template/nodes/w6-verification/gen/check-cue-coverage.mjs",
            "--workspace", "{{WORKSPACE}}",
            "--run", "{{RUN}}",
            "--report-out", "{{RUN}}/optimize/substrate/cue-coverage.json"
          ],
          "note": "MEASURE (post-run, report-only): every cue script-cues.json declares must get an independently-addressed verdict row in verification.md — catches a silently-dropped cue. Report-only; never blocks (see gen/check-cue-coverage.mjs)."
        },
        "writes": ["{{RUN}}/optimize/substrate/cue-coverage.json"]
      },
      {
        "id": "gate-citations",
        "run": {
          "cmd": "node",
          "args": [
            "{{WORKSPACE}}/.piflow/lesson-build/template/nodes/w6-verification/gen/check-gate-citations.mjs",
            "--workspace", "{{WORKSPACE}}",
            "--run", "{{RUN}}",
            "--report-out", "{{RUN}}/optimize/substrate/gate-citations.json"
          ],
          "note": "MEASURE (post-run, report-only): every non-clean bbox-manifest.json summary signal (gatesFailed[]/measuredCollisionCount/captionIntrusionCount) must be at least MENTIONED in verification.md — the lesson-verification SKILL forbids silent acceptance. Mechanical completeness only; whether the justification is GOOD is criteria.md R2/R4's job."
        },
        "writes": ["{{RUN}}/optimize/substrate/gate-citations.json"]
      }
    ],
    "criteria": "nodes/w6-verification/criteria.md",
    "verifyDefault": "full"
  }
}
