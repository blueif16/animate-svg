{
  "id": "w3a-voice-asr",
  "phase": "assets",
  "deps": [
    "w2b-audio-captions",
    "w2c-sound-design"
  ],
  "prompt": { "file": "prompt.md" },
  "tools": { "allow": ["read", "write", "edit", "bash", "submit_result"], "deny": [] },
  "contract": {
    "artifacts": [
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/generated/{{state.camelLessonId}}Clips.ts",
      "{{WORKSPACE}}/remotion-svg-primitives/public/audio/{{arg.lessonId}}-voice.wav",
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/generated/{{state.camelLessonId}}Timing.ts",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/audio-gate.json"
    ],
    "owns": [
      "{{WORKSPACE}}/remotion-svg-primitives/public/audio/{{arg.lessonId}}/clips",
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/generated/{{state.camelLessonId}}Clips.ts",
      "{{WORKSPACE}}/remotion-svg-primitives/public/audio/{{arg.lessonId}}-voice.wav",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/gemini-voice.json",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/asr-alignment.json",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/audio-gate.json",
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/generated/{{state.camelLessonId}}Timing.ts",
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/script-cues.json",
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/_logs/w3a-voice-asr.md"
    ],
    "readScope": [
      "{{WORKSPACE}}/remotion-svg-primitives/src",
      "{{WORKSPACE}}/remotion-svg-primitives/public",
      "{{WORKSPACE}}/remotion-svg-primitives/scripts",
      "{{WORKSPACE}}/remotion-svg-primitives/package.json",
      "{{WORKSPACE}}/remotion-svg-primitives/tsconfig.json",
      "{{WORKSPACE}}/remotion-svg-primitives/eslint.config.mjs",
      "{{WORKSPACE}}/remotion-svg-primitives/remotion.config.ts",
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}",
      "{{WORKSPACE}}/.agents"
    ],
    "execCwd": "{{WORKSPACE}}/remotion-svg-primitives",
    "execReads": [
      "{{WORKSPACE}}/../shared-narration",
      "{{WORKSPACE}}/../Omniscience/agent/.venv",
      "{{WORKSPACE}}/../Omniscience/agent/models/voice/asr"
    ],
    "returnMode": "optional"
  },
  "op": [
    {
      "when": "pre",
      "reads": [
        "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/script-cues.json",
        "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/pipeline.json"
      ]
    },
    {
      "when": "post",
      "run": {
        "cmd": "npm",
        "args": ["run", "lesson:freeze-check", "--", "--config", "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/pipeline.json"],
        "cwd": "{{WORKSPACE}}/remotion-svg-primitives"
      },
      "onFailure": "block"
    }
  ],
  "checks": {
    "post": [
      { "kind": "non-empty", "path": "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/generated/{{state.camelLessonId}}Clips.ts" },
      { "kind": "non-empty", "path": "{{WORKSPACE}}/remotion-svg-primitives/public/audio/{{arg.lessonId}}-voice.wav" },
      { "kind": "non-empty", "path": "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/generated/{{state.camelLessonId}}Timing.ts" },
      { "kind": "non-empty", "path": "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/audio-gate.json" },
      { "kind": "json-parses", "path": "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/audio-gate.json" }
    ]
  },
  "policy": { "fail": "block" },
  "return": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "node": { "type": "string" },
      "status": { "type": "string", "enum": ["ok", "gap", "blocked"] },
      "outputArtifacts": { "type": "array", "items": { "type": "string" } },
      "summary": { "type": "string" },
      "issues": { "type": "array", "items": { "type": "string" } },
      "pipelineFindings": { "type": "array", "items": { "type": "string" } },
      "accepted": { "type": "boolean" },
      "cueAudit": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string" },
            "matchScore": { "type": "number" },
            "durationFrames": { "type": "number" },
            "reRolled": { "type": "boolean" }
          },
          "required": ["id", "matchScore"]
        }
      }
    },
    "required": ["node", "status", "outputArtifacts", "summary", "pipelineFindings", "accepted", "cueAudit"]
  }
}
