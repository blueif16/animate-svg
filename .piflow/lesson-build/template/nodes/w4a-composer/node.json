{
  "id": "w4a-composer",
  "phase": "compose",
  "deps": [
    "w3-5-reconcile"
  ],
  "prompt": {
    "file": "prompt.md"
  },
  "tools": {
    "allow": [
      "read",
      "write",
      "edit",
      "bash",
      "submit_result"
    ],
    "deny": []
  },
  "inject": [
    "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/storyboard.md",
    "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/visual-design.md",
    "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/audio-cues.json"
  ],
  "contract": {
    "artifacts": [
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{arg.composition}}.tsx",
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{arg.camelLessonId}}LessonScene.tsx",
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{arg.camelLessonId}}/layout.ts",
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{arg.camelLessonId}}/manifest.ts",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json"
    ],
    "owns": [
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{arg.composition}}.tsx",
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{arg.camelLessonId}}LessonScene.tsx",
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{arg.camelLessonId}}/*",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json",
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/_logs/w4a-composer.md"
    ],
    "readScope": [
      "{{WORKSPACE}}/remotion-svg-primitives/src",
      "{{WORKSPACE}}/remotion-svg-primitives/public",
      "{{WORKSPACE}}/remotion-svg-primitives/scripts",
      "{{WORKSPACE}}/remotion-svg-primitives/package.json",
      "{{WORKSPACE}}/remotion-svg-primitives/tsconfig.json",
      "{{WORKSPACE}}/remotion-svg-primitives/eslint.config.mjs",
      "{{WORKSPACE}}/remotion-svg-primitives/remotion.config.ts",
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}",
      "{{WORKSPACE}}/.agents"
    ],
    "returnMode": "optional"
  },
  "hooks": {
    "merge": {
      "ops": [
        {
          "run": {
            "cmd": "npm",
            "args": ["run", "lesson:check", "--", "--config", "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/pipeline.json"],
            "cwd": "{{WORKSPACE}}/remotion-svg-primitives",
            "note": "COMPOSER SELF-GATE (exit-routed, runs AFTER the model finishes the scene). Re-runs lesson:check against the FINAL scene so the gated bbox-manifest.json is FRESH — a self-reported 'ok' left with defects is caught. lesson:check exits 1 (and blocks) on the HARD gates: the declared<=>measured bbox-binding bijection and the LUFS gate. The OVERLAP (measuredCollisionCount) and caption-intrusion (captionIntrusionCount) defects are WARN-only / exit-0 in the script, and a crash also forces exit 0 — so those are enforced by the checks.post content gates below. Without them an element overlap, a caption intrusion, or a gate-that-never-ran would all ship GREEN."
          }
        }
      ]
    }
  },
  "checks": {
    "post": [
      {
        "kind": "non-empty",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{arg.composition}}.tsx"
      },
      {
        "kind": "non-empty",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{arg.camelLessonId}}LessonScene.tsx"
      },
      {
        "kind": "non-empty",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{arg.camelLessonId}}/layout.ts"
      },
      {
        "kind": "non-empty",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{arg.camelLessonId}}/manifest.ts"
      },
      {
        "kind": "json-parses",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json"
      },
      {
        "kind": "regex-present",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json",
        "param": "\"method\"\\s*:\\s*\"getBBox\"",
        "severity": "fail"
      },
      {
        "kind": "regex-present",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json",
        "param": "\"measuredCollisionCount\"\\s*:\\s*0\\b",
        "severity": "fail"
      },
      {
        "kind": "regex-present",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json",
        "param": "\"captionIntrusionCount\"\\s*:\\s*0\\b",
        "severity": "fail"
      }
    ]
  },
  "policy": {
    "fail": "block"
  },
  "return": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "node": { "type": "string" },
      "status": { "type": "string", "enum": ["ok", "gap", "blocked"] },
      "outputArtifacts": { "type": "array", "items": { "type": "string" } },
      "summary": { "type": "string" },
      "issues": { "type": "array", "items": { "type": "string" } },
      "pipelineFindings": { "type": "array", "items": { "type": "string" } }
    },
    "required": ["node", "status", "outputArtifacts", "summary", "pipelineFindings"]
  }
}
