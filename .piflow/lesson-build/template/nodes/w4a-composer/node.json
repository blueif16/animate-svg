{
  "id": "w4a-composer",
  "phase": "compose",
  "deps": [
    "w3-5-reconcile"
  ],
  "prompt": {
    "file": "prompt.md"
  },
  "tools": {
    "allow": [
      "read",
      "write",
      "edit",
      "bash",
      "submit_result"
    ],
    "deny": []
  },
  "contract": {
    "artifacts": [
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{state.composition}}.tsx",
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{state.camelLessonId}}LessonScene.tsx",
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{state.camelLessonId}}/layout.ts",
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{state.camelLessonId}}/manifest.ts",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json"
    ],
    "owns": [
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{state.composition}}.tsx",
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{state.camelLessonId}}LessonScene.tsx",
      "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{state.camelLessonId}}/*",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json",
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/_logs/w4a-composer.md"
    ],
    "readScope": [
      "{{WORKSPACE}}/remotion-svg-primitives/src",
      "{{WORKSPACE}}/remotion-svg-primitives/public",
      "{{WORKSPACE}}/remotion-svg-primitives/scripts",
      "{{WORKSPACE}}/remotion-svg-primitives/package.json",
      "{{WORKSPACE}}/remotion-svg-primitives/tsconfig.json",
      "{{WORKSPACE}}/remotion-svg-primitives/eslint.config.mjs",
      "{{WORKSPACE}}/remotion-svg-primitives/remotion.config.ts",
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}",
      "{{WORKSPACE}}/.agents",
      "{{WORKSPACE}}/../shared-narration",
      "{{WORKSPACE}}/../shared-sound",
      "{{WORKSPACE}}/../shared-3d"
    ],
    "returnMode": "optional"
  },
  "op": [
    { "when": "pre", "reads": ["{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/storyboard.md"] },
    { "when": "pre", "reads": ["{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/visual-design.md"] },
    { "when": "pre", "reads": ["{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/audio-cues.json"] },
    {
      "when": "post",
      "run": {
        "cmd": "node",
        "args": ["scripts/lesson-measured.mjs", "--config", "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/pipeline.json"],
        "cwd": "{{WORKSPACE}}/remotion-svg-primitives"
      },
      "onFailure": "block"
    }
  ],
  "checks": {
    "post": [
      {
        "kind": "non-empty",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{state.composition}}.tsx"
      },
      {
        "kind": "non-empty",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{state.camelLessonId}}LessonScene.tsx"
      },
      {
        "kind": "non-empty",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{state.camelLessonId}}/layout.ts"
      },
      {
        "kind": "non-empty",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{state.camelLessonId}}/manifest.ts"
      },
      {
        "kind": "json-parses",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json"
      },
      {
        "kind": "regex-present",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json",
        "param": "\"method\"\\s*:\\s*\"getBBox\"",
        "severity": "fail"
      },
      {
        "kind": "regex-present",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json",
        "param": "\"measuredCollisionCount\"\\s*:\\s*0\\b",
        "severity": "fail"
      },
      {
        "kind": "regex-present",
        "path": "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json",
        "param": "\"captionIntrusionCount\"\\s*:\\s*0\\b",
        "severity": "fail"
      }
    ]
  },
  "policy": {
    "fail": "block"
  },
  "optimize": {
    "measure": [
      {
        "id": "scene-tsx-non-empty",
        "gate": { "kind": "non-empty", "path": "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{state.composition}}.tsx" },
        "note": "MEASURE (post-run, out-of-band, NON-BLOCKING) — mirrors this node's own live checks.post so the optimize substrate's hard-measure report (optimize/substrate/measure.w4a-composer.json) carries the SAME floor axes triage reads, entirely parallel to the run's own gates."
      },
      {
        "id": "scene-file-non-empty",
        "gate": { "kind": "non-empty", "path": "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{state.camelLessonId}}LessonScene.tsx" }
      },
      {
        "id": "layout-non-empty",
        "gate": { "kind": "non-empty", "path": "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{state.camelLessonId}}/layout.ts" }
      },
      {
        "id": "manifest-non-empty",
        "gate": { "kind": "non-empty", "path": "{{WORKSPACE}}/remotion-svg-primitives/src/lessons/{{state.camelLessonId}}/manifest.ts" }
      },
      {
        "id": "bbox-manifest-parses",
        "gate": { "kind": "json-parses", "path": "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json" }
      },
      {
        "id": "measured-pass-ran",
        "gate": {
          "kind": "regex-present",
          "path": "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json",
          "param": "\"method\"\\s*:\\s*\"getBBox\""
        },
        "note": "A SKIPPED/crashed measured pass means the gate that would have caught a laundered self-report never ran — that is itself the defect, not a clean bill."
      },
      {
        "id": "measured-collision-floor",
        "gate": {
          "kind": "regex-present",
          "path": "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json",
          "param": "\"measuredCollisionCount\"\\s*:\\s*0\\b"
        },
        "note": "Reads the MANIFEST directly, never the model's self-report — this is the durable fix for the composer self-grade 'laundering' recurrence on record in .agents/tracked-systems.md (W4a reporting 0 collisions while its own manifest disagreed). See nodes/w4a-composer/memory.md."
      },
      {
        "id": "caption-intrusion-floor",
        "gate": {
          "kind": "regex-present",
          "path": "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/bbox-manifest.json",
          "param": "\"captionIntrusionCount\"\\s*:\\s*0\\b"
        }
      }
    ],
    "criteria": "nodes/w4a-composer/criteria.md"
  },
  "return": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "node": { "type": "string" },
      "status": { "type": "string", "enum": ["ok", "gap", "blocked"] },
      "outputArtifacts": { "type": "array", "items": { "type": "string" } },
      "summary": { "type": "string" },
      "issues": { "type": "array", "items": { "type": "string" } },
      "pipelineFindings": { "type": "array", "items": { "type": "string" } }
    },
    "required": ["node", "status", "outputArtifacts", "summary", "pipelineFindings"]
  }
}
