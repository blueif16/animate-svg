{
  "id": "w3b-primitive-build",
  "phase": "assets",
  "deps": [
    "w2b-audio-captions",
    "w2c-sound-design"
  ],
  "prompt": { "file": "prompt.md" },
  "tools": {
    "allow": [
      "read",
      "write",
      "edit",
      "bash",
      "submit_result"
    ],
    "deny": []
  },
  "inject": [
    "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/storyboard.md",
    "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/visual-design.md"
  ],
  "contract": {
    "artifacts": [
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/primitive-gap-scan.md"
    ],
    "owns": [
      "{{WORKSPACE}}/remotion-svg-primitives/src/shape-primitives/",
      "{{WORKSPACE}}/remotion-svg-primitives/src/capabilities/primitive-registry.json",
      "{{WORKSPACE}}/remotion-svg-primitives/src/capabilities/catalog-digest.md",
      "{{WORKSPACE}}/remotion-svg-primitives/src/capabilities/catalog-digest.schema.json",
      "{{WORKSPACE}}/remotion-svg-primitives/src/component-gallery/demoProps.tsx",
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/primitive-gap-scan.md",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}/primitive-checks",
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/_logs/w3b-primitive-build.md"
    ],
    "readScope": [
      "{{WORKSPACE}}/remotion-svg-primitives/src",
      "{{WORKSPACE}}/remotion-svg-primitives/public",
      "{{WORKSPACE}}/remotion-svg-primitives/scripts",
      "{{WORKSPACE}}/remotion-svg-primitives/package.json",
      "{{WORKSPACE}}/remotion-svg-primitives/tsconfig.json",
      "{{WORKSPACE}}/remotion-svg-primitives/eslint.config.mjs",
      "{{WORKSPACE}}/remotion-svg-primitives/remotion.config.ts",
      "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}",
      "{{WORKSPACE}}/remotion-svg-primitives/out/{{arg.lessonId}}",
      "{{WORKSPACE}}/.agents"
    ],
    "returnMode": "optional"
  },
  "checks": {
    "post": [
      { "kind": "non-empty", "path": "{{WORKSPACE}}/remotion-svg-primitives/lesson-data/{{arg.lessonId}}/primitive-gap-scan.md" }
    ]
  },
  "policy": { "fail": "block" },
  "return": { "type": "object", "additionalProperties": false,
    "properties": {
      "node": { "type": "string" },
      "status": { "type": "string", "enum": ["ok", "gap", "blocked"] },
      "outputArtifacts": { "type": "array", "items": { "type": "string" } },
      "summary": { "type": "string" },
      "issues": { "type": "array", "items": { "type": "string" } },
      "pipelineFindings": { "type": "array", "items": { "type": "string" } }
    },
    "required": ["node", "status", "outputArtifacts", "summary", "pipelineFindings"] }
}
