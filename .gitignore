node_modules/
remotion-svg-primitives/node_modules/
remotion-svg-primitives/out/
remotion-svg-primitives/build/

.DS_Store
*.log

.env
.env.local

# Heavy / generated audio media — keep out of git (small SFX + stings + the
# JSON/license manifests stay tracked). Regenerate beds per
# public/audio/_SOURCING.md; voice via `npm run lesson:voice`.
remotion-svg-primitives/public/audio/_beds/*.wav
remotion-svg-primitives/public/audio/*-voice.wav
# v4 cue-anchored audio: per-cue voice clips (TTS, regenerable via lesson:voice).
remotion-svg-primitives/public/audio/*/clips/

# Generated per-lesson render artifacts — derivable from the pipeline, kept
# out of git. Authored .md/.json inputs under lesson-data/ stay tracked.
remotion-svg-primitives/lesson-data/**/*.mp4
remotion-svg-primitives/lesson-data/**/*.png

# Archived prior pipeline runs — heavy generated output (MP4, contact PNGs,
# per-node event transcripts, voice WAV clips). Snapshots, not source.
_prior-runs/

# Editor/pipeline backup snapshots + one-off throwaway scripts.
*.backup
remotion-svg-primitives/compute_timeline.js
