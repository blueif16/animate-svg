{
  "name": "remotion-svg-primitives",
  "version": "1.0.0",
  "description": "My Remotion video",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20 <24"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@remotion/cli": "4.0.462",
    "@remotion/layout-utils": "4.0.462",
    "@remotion/tailwind-v4": "4.0.462",
    "@remotion/three": "4.0.462",
    "@studio/narration-kit": "file:../../shared-narration",
    "@studio/sound-kit": "file:../../shared-sound",
    "@studio/three-effects": "file:../../shared-3d",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.462",
    "tailwindcss": "4.0.0",
    "three": "^0.184.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.462",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "sharp": "^0.34.5",
    "tsx": "^4.22.3",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "remotion studio --port 6173",
    "build": "remotion bundle",
    "upgrade": "remotion upgrade",
    "lint": "node scripts/check-legacy-boundary.mjs && eslint src && tsc",
    "test:layout": "tsx src/layout/fitToZone.test.ts",
    "test:sfx-budget": "tsx src/lesson-media/LessonSfxLayer.test.ts",
    "lesson:render": "node scripts/render-complete-lesson.mjs",
    "lesson:scaffold": "node scripts/scaffold-lesson.mjs",
    "lesson:voice": "node node_modules/@studio/narration-kit/bin/generate-voice.mjs --align",
    "lesson:check": "node scripts/lesson-check.mjs",
    "lesson:audio-gate": "node scripts/lesson-audio-gate.mjs",
    "lesson:contact-sheet": "node scripts/make-contact-sheet.mjs",
    "lesson:bbox": "node scripts/lesson-bbox-overlay.mjs",
    "lesson:animatic": "node scripts/lesson-animatic.mjs",
    "lessons:registry": "node scripts/build-lesson-registry.mjs",
    "gallery:data": "node scripts/gallery/build-gallery-data.mjs",
    "gallery:previews": "node scripts/gallery/render-previews.mjs",
    "gallery": "node scripts/gallery/serve.mjs",
    "voice:lesson": "node node_modules/@studio/narration-kit/bin/generate-voice.mjs --align",
    "icons:build": "node scripts/registry/build-icon-assets.mjs",
    "registry:build": "node scripts/registry/build-icon-assets.mjs && node scripts/registry/build-registry.mjs && node scripts/registry/catalog-digest.mjs && node scripts/registry/build-recency.mjs && node --no-warnings=ExperimentalWarning scripts/registry/export-schema.mjs && node scripts/build-lesson-registry.mjs",
    "registry:check": "node scripts/registry/build-icon-assets.mjs --check && node scripts/registry/build-registry.mjs --check && node scripts/registry/catalog-digest.mjs --check && node --no-warnings=ExperimentalWarning scripts/registry/export-schema.mjs --check && node scripts/registry/check-gallery.mjs && node scripts/registry/check-deprecated-refs.mjs && node scripts/build-lesson-registry.mjs --check",
    "registry:check-gallery": "node scripts/registry/check-gallery.mjs",
    "registry:check-deprecated": "node scripts/registry/check-deprecated-refs.mjs",
    "registry:check-lesson": "node scripts/registry/check-lesson-primitives.mjs",
    "registry:digest": "node scripts/registry/catalog-digest.mjs",
    "registry:recency": "node scripts/registry/build-recency.mjs",
    "registry:drift": "node scripts/registry/drift-report.mjs",
    "registry:schema-check": "node --no-warnings=ExperimentalWarning scripts/registry/schema-check.mjs",
    "registry:schema-export": "node --no-warnings=ExperimentalWarning scripts/registry/export-schema.mjs",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "sideEffects": [
    "*.css"
  ]
}
